# OpenRouter is the default provider since it exposes every major model behind one API.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional direct provider keys. Only set the ones you want to use.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Default model slug used when createDefaultAgent() is called. Override as needed.
# Any OpenRouter-supported model works; see https://openrouter.ai/models
AEF_DEFAULT_MODEL=anthropic/claude-sonnet-4

# Optional: request attribution for OpenRouter's leaderboards
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_SITE_NAME=My App
