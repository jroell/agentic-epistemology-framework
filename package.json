{
  "name": "agentic-epistemology-framework",
  "version": "2.0.0",
  "description": "TypeScript reference implementation of the Agentic Epistemology Framework (AEF). Provider-agnostic via the Vercel AI SDK with OpenRouter by default.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent",
    "epistemology",
    "ai",
    "ai-sdk",
    "openrouter",
    "reasoning",
    "belief",
    "multi-agent",
    "frame",
    "vercel-ai-sdk"
  ],
  "author": "Jason Roell",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@openrouter/ai-sdk-provider": "^1.0.0",
    "ai": "^5.0.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.2",
    "@vitest/ui": "^3.2.2",
    "eslint": "^9.17.0",
    "msw": "^2.13.4",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typedoc": "^0.27.6",
    "typescript": "^5.8.2",
    "vitest": "^3.2.2"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jroell/agentic-epistemology-framework.git"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
